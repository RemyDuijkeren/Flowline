{
    "private": true,
    "devDependencies": {
        "@microsoft/eslint-plugin-power-apps": "^0.5.1",
        "@rollup/plugin-eslint": "^9.2.0",
        "@rollup/plugin-typescript": "^12.3.0",
        "@types/xrm": "^9.0.94",
        "@typescript-eslint/parser": "^8.60.1",
        "eslint": "^9",
        "rollup": "^4.61.0",
        "tslib": "^2.8.1",
        "typescript": "^6.0.3"
    },
    "scripts": {
        "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
        "build": "npm run clean && npm run build:static && npm run build:js",
        "build:js": "rollup --config",
        "build:static": "node -e \"require('fs').cpSync('public','dist',{recursive:true})\""
    }
}
